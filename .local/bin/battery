#!/bin/bash

if [ ! -d "/sys/class/power_supply/BAT0/" ]; then
    echo "’ć”"
else
    bat="$(cat /sys/class/power_supply/BAT0/capacity)"
    stat="$(cat /sys/class/power_supply/BAT0/status)"

    if [[ $stat != "Discharging" ]]; then
        echo "’ć” $bat%"
    else
        if [[ $bat -gt 85 ]] 
        then
	        icon="’ēĆ "
        elif [[ $bat -gt 60 ]]
        then
	        icon="’ēü "
        elif [[ $bat -gt 40 ]]
        then
	        icon="’ēé "
        elif [[ $bat -gt 15 ]]
        then
	        icon="’ēā "
        else
	        icon="’ēä "
        fi

        if [[ $bat -le 15 ]]
        then
            echo "!! $icon$bat% !!"
        else
            echo "$icon$bat%"
        fi
    fi
fi
