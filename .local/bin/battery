#!/bin/bash

bat="$(cat /sys/class/power_supply/BAT0/capacity)"
stat="$(cat /sys/class/power_supply/BAT0/status)"

if [[ $bat -gt 75 ]] 
then
	icon="ÔČÄ "
elif [[ $bat -gt 60 ]]
then
	icon="ÔČĀ "
elif [[ $bat -gt 40 ]]
then
	icon="ÔČā "
elif [[ $bat -gt 20 ]]
then
	icon="ÔČÉ "
else
	icon="ÔČĄ "
fi

echo "$icon$bat%"
